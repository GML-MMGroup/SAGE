        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "tool_name": "remove_from_cart",
      "description": "Remove a specified quantity of a product from the user's cart. If the user asks to remove an item/product from the cart without specifying a quantity, use the product's current cart quantity so the whole cart item is removed; use a smaller or specific quantity only when explicitly requested.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "qty": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        },
        "required": [
          "user_id",
          "product_name",
          "qty"
        ]
      }
    }
  },
