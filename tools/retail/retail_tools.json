            "type": "number",
            "minimum": 0,
            "description": "Tax rate (e.g., 0.08 for 8%)."
          },
          "discount": {
            "type": "number",
            "minimum": 0,
            "maximum": 1.0,
            "description": "Discount factor: final amount = price * discount."
          }
        },
        "required": [
          "user_id",
          "product_name",
          "qty",
          "category",
          "price",
