[
  {
    "type": "function",
    "function": {
      "tool_name": "add_product",
      "description": "Add or update a product in the global catalog. Product is keyed by 'name'. Price is tax-inclusive. Discount is a factor (1.0 = full price).",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "product_name": {
            "type": "string",
            "description": "Unique product name (primary key)."
          },
          "category": {
            "type": "string"
          },
          "price": {
            "type": "number",
            "minimum": 0,
            "description": "Shelf price including tax."
          },
          "tax_rate": {
            "type": "number",
            "minimum": 0,
            "description": "Tax rate (e.g., 0.08 for 8%)."
          },
          "discount": {
            "type": "number",
            "minimum": 0,
            "maximum": 1.0,
            "description": "Discount factor: final amount = price * discount."
          },
          "nutritional_characteristics": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "low_calories",
                "low_fat",
                "low_sugar",
                "low_sodium",
                "no_additives",
                "high_fiber",
                "high_protein",
                "high_calcium",
                "sugar_free",
                "gluten_free",
                "vegan",
                "high_calories",
                "high_fat",
                "high_sodium",
                "high_sugar"
              ]
            },
            "description": "Nutritional/health tags."
          },
          "taste": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "sweet",
                "salty",
                "spicy",
                "sour",
                "bitter",
                "umami",
                "mild",
                "savory",
                "creamy",
                "dry",
                "minty",
                "nutty",
                "strong",
                "tangy",
                "·"
              ]
            },
            "description": "Taste profiles."
          },
          "country_of_origin": {
            "type": "string",
            "description": "Country where the product originates."
          },
          "nutrition": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "basis": {
                "type": "string",
                "enum": [
                  "PER_100G",
                  "PER_SERVING"
                ]
              },
              "serving_size_g": {
                "type": "number"
              },
              "calories_kcal": {
                "type": "number"
              },
              "protein_g": {
                "type": "number"
              },
              "fat_g": {
                "type": "number"
              },
              "carbs_g": {
                "type": "number"
              },
              "sugar_g": {
                "type": "number"
              },
              "sodium_mg": {
                "type": "number"
              },
              "fiber_g": {
                "type": "number"
              }
            },
            "required": [
              "basis"
            ]
          },
          "allergens": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "product_name",
          "category",
          "price",
          "tax_rate",
          "discount",
          "nutritional_characteristics",
          "taste",
          "country_of_origin"
        ]
      }
    }
  },
