  {
    "type": "function",
    "function": {
      "tool_name": "get_user_order_summary",
      "description": "Retrieve all items in a user's current order, including individual dishes and set meals. Each returned item includes item_type ('dish' or 'set_meal'); for total nutrition, payment, or tax calculations, pass set meal names directly to the compute tool without expanding them; if item_type is 'set_meal' and the task asks about allergens, tags, included dishes, or component-level nutrition, call get_set_meal_details before deciding. item_type is informational only; do not pass item_type into compute, add, or remove tool parameters. For compute_total_* tools, pass only dish_name and quantity for each order item.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string"
          }
        },
        "required": [
          "user_id"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "tool_name": "compute_total_payment",
      "description": "Compute total payable amount for the specified final order items: sum(tax-inclusive price * discount * qty). The returned total_payment is already tax-inclusive; do not add compute_total_tax to total_payment. compute_total_tax only reports the tax portion included inside total_payment. The dishes list may contain both individual dish names and set meal names. If the final order contains a set meal, pass the set meal name as one item and do not expand it into included dishes.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The unique identifier of the user"
          },
          "dishes": {
            "type": "array",
            "description": "Final order items to calculate total payment for. Include individual dishes and set meals exactly as they appear in the order; do not expand set meals into their included dishes.",
            "items": {
              "type": "object",
              "properties": {
                "dish_name": {
                  "type": "string",
                  "description": "Name of an individual dish or set meal in the final order"
                },
                "quantity": {
                  "type": "integer",
                  "description": "Quantity of the dish to purchase"
                }
              },
              "required": [
                "dish_name",
                "quantity"
              ]
            }
          }
        },
        "required": [
          "user_id",
          "dishes"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "tool_name": "compute_total_tax",
      "description": "Compute total tax amount for the specified final order items. Since price is tax-inclusive, tax per item = (price * tax_rate / (1 + tax_rate)) * discount * qty. The dishes list may contain both individual dish names and set meal names. If the final order contains a set meal, pass the set meal name as one item and do not expand it into included dishes.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The unique identifier of the user"
          },
          "dishes": {
            "type": "array",
            "description": "Final order items to calculate total tax for. Include individual dishes and set meals exactly as they appear in the order; do not expand set meals into their included dishes.",
            "items": {
              "type": "object",
              "properties": {
                "dish_name": {
                  "type": "string",
                  "description": "Name of an individual dish or set meal in the final order"
                },
                "quantity": {
                  "type": "integer",
                  "description": "Quantity of the dish to purchase"
                }
              },
              "required": [
                "dish_name",
                "quantity"
              ]
            }
          }
        },
        "required": [
          "user_id",
          "dishes"
        ]
      }
    }
  },
  {
    "type": "function",
    "function": {
      "tool_name": "compute_total_nutrition",
      "description": "Compute total nutrition values across all specified final order items. The dishes list may contain both individual dish names and set meal names. If the final order contains a set meal, pass the set meal name as one item and do not expand it into included dishes.",
      "parameters": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string",
            "description": "The unique identifier of the user"
          },
          "dishes": {
            "type": "array",
            "description": "Final order items to calculate total nutrition values for. Include individual dishes and set meals exactly as they appear in the order; do not expand set meals into their included dishes.",
            "items": {
              "type": "object",
              "properties": {
                "dish_name": {
                  "type": "string",
                  "description": "Name of an individual dish or set meal in the final order"
                },
                "quantity": {
                  "type": "integer",
                  "description": "Quantity of the dish to purchase"
                }
              },
              "required": [
                "dish_name",
                "quantity"
              ]
            }
          }
        },
        "required": [
          "user_id",
          "dishes"
        ]
      }
    }
  },
